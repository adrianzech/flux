{
  "extends": ["config:recommended"],
  "enabledManagers": ["flux", "kubernetes", "helm-values", "custom.regex"],
  "flux": {
    "managerFilePatterns": [
      "/^apps\\/.*\\/base\\/release.*\\.ya?ml$/",
      "/^infrastructure\\/.*\\/base\\/.*\\/release.*\\.ya?ml$/",
      "/^infrastructure\\/base\\/sources\\/.*-repository\\.ya?ml$/"
    ]
  },
  "timezone": "Europe/Vienna",
  "labels": ["dependencies", "renovate"],
  "prConcurrentLimit": 10,
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["getmeili/meilisearch"],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track container image tags in Flux HelmRelease values",
      "managerFilePatterns": [
        "/^apps\\/.*\\/base\\/release.*\\.ya?ml$/",
        "/^infrastructure\\/.*\\/base\\/.*\\/release.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "repository:\\s*(?<depName>[^\\s]+)\\s*\\n\\s*tag:\\s*\"?(?<currentValue>[^\"\\s]+)\"?"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Track Immich server image tag in HelmRelease values",
      "managerFilePatterns": [
        "/^apps\\/immich\\/base\\/release\\.ya?ml$/"
      ],
      "matchStrings": [
        "server:\\s*\\n(?:\\s+.*\\n)*?\\s+image:\\s*\\n\\s+tag:\\s*\"?(?<currentValue>[^\"\\s]+)\"?"
      ],
      "depNameTemplate": "ghcr.io/immich-app/immich-server",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Track Immich machine learning image tag in HelmRelease values",
      "managerFilePatterns": [
        "/^apps\\/immich\\/base\\/release\\.ya?ml$/"
      ],
      "matchStrings": [
        "machine-learning:\\s*\\n(?:\\s+.*\\n)*?\\s+image:\\s*\\n\\s+tag:\\s*\"?(?<currentValue>[^\"\\s]+)\"?"
      ],
      "depNameTemplate": "ghcr.io/immich-app/immich-machine-learning",
      "datasourceTemplate": "docker"
    }
  ]
}
